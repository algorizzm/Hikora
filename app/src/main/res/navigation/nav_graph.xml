<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- ===================== -->
    <!-- 🔰 SPLASH / ENTRY POINT -->
    <!-- ===================== -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.hikora.ui.main.SplashFragment"
        android:label="Launcher" />

    <!-- ===================== -->
    <!-- 🔐 AUTH FLOW -->
    <!-- ===================== -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.hikora.ui.auth.LoginFragment"
        android:label="Login">

        <!-- Navigate to Signup -->
        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment" />

        <!-- Temporary direct navigation (can be removed if using global auth observer only) -->
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.hikora.ui.auth.SignupFragment"
        android:label="Signup">

        <!-- Navigate back to Login -->
        <action
            android:id="@+id/action_signupFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <!-- ===================== -->
    <!-- 🏠 MAIN APP SCREENS -->
    <!-- ===================== -->

    <!-- Home Dashboard -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.hikora.ui.home.HomeFragment"
        android:label="Home" />

    <!-- User Profile -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.hikora.ui.profile.ProfileFragment"
        android:label="Profile">

        <!-- Logout / session invalidation fallback -->
        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <!-- ===================== -->
    <!-- 📱 FEATURE PLACEHOLDERS -->
    <!-- ===================== -->

    <!-- Hikes Feature -->
    <fragment
        android:id="@+id/hikesFragment"
        android:name="com.hikora.ui.hikes.HikesFragment"
        android:label="Hikes" />

    <!-- Reels Feature -->
    <fragment
        android:id="@+id/reelsFragment"
        android:name="com.hikora.ui.reels.ReelsFragment"
        android:label="Reels" />

    <!-- Messaging Feature -->
    <fragment
        android:id="@+id/messagesFragment"
        android:name="com.hikora.ui.messages.MessagesFragment"
        android:label="Messages" />

</navigation>