<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B301F"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="@drawable/bg_translucent_circle"
            android:src="@drawable/ic_chevron_left"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivShieldLogo"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="60dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/ic_shield_lock"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Change\nPassword"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivShieldLogo"
            app:layout_constraintStart_toEndOf="@id/ivShieldLogo"
            app:layout_constraintTop_toTopOf="@id/ivShieldLogo" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="140dp"
            android:background="@drawable/bg_top_rounded_white"
            android:padding="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0">

            <LinearLayout
                android:id="@+id/secureZoneBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edit_field"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="16dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_shield_lock"
                    app:tint="#8CA99C" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Secure zone"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Use letters, numbers &amp; symbols\nfor a stronger password"
                        android:textColor="#8CA99C"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/lblCurrentPass"
                style="@style/HikoraFieldLabel"
                android:layout_marginTop="24dp"
                android:text="Current Password"
                app:layout_constraintTop_toBottomOf="@id/secureZoneBanner"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etCurrentPassword"
                style="@style/HikoraEditText"
                android:layout_marginTop="8dp"
                android:inputType="textPassword"
                android:hint="••••••••"
                app:layout_constraintTop_toBottomOf="@id/lblCurrentPass" />

            <TextView
                android:id="@+id/lblNewPass"
                style="@style/HikoraFieldLabel"
                android:layout_marginTop="20dp"
                android:text="New Password"
                app:layout_constraintTop_toBottomOf="@id/etCurrentPassword"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etNewPassword"
                style="@style/HikoraEditText"
                android:layout_marginTop="8dp"
                android:inputType="textPassword"
                android:hint="••••••••"
                app:layout_constraintTop_toBottomOf="@id/lblNewPass" />

            <TextView
                android:id="@+id/lblConfirmPass"
                style="@style/HikoraFieldLabel"
                android:layout_marginTop="20dp"
                android:text="Confirm New Password"
                app:layout_constraintTop_toBottomOf="@id/etNewPassword"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/etConfirmPassword"
                style="@style/HikoraEditText"
                android:layout_marginTop="8dp"
                android:inputType="textPassword"
                android:hint="••••••••"
                app:layout_constraintTop_toBottomOf="@id/lblConfirmPass" />

            <LinearLayout
                android:id="@+id/requirementsBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_edit_field"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/etConfirmPassword">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requirements"
                    android:textColor="#0B301F"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/imgReqLen"
                        android:layout_width="18dp"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#8CA99C" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="At least 8 characters"
                        android:textColor="#0B301F"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/imgReqUpper"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#8CA99C" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="One upper case letter"
                        android:textColor="#0B301F"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/imgReqSpecial"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#8CA99C" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="One special character"
                        android:textColor="#0B301F"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/btnUpdatePassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#8CA99C"
                android:text="Update Password"
                android:textAllCaps="false"
                android:textColor="#0B301F"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/requirementsBox" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>