<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B301F"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="@drawable/bg_translucent_circle"
            android:src="@drawable/ic_chevron_left"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/hikoraLogo"
            android:layout_width="71dp"
            android:layout_height="68dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/hikora_logo_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Edit Profile"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btnTopSave"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="16dp"
            android:backgroundTint="#6D8B7D"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Save"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvHeaderTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvHeaderTitle" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/whiteCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="120dp"
            android:background="@drawable/bg_top_rounded_white"
            android:padding="24dp"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/headerSpacer"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvChangePhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tap to change photo"
                android:textColor="#6D8B7D"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerSpacer" />

            <TextView
                android:id="@+id/lblPersonalInfo"
                style="@style/HikoraSectionLabel"
                android:layout_marginTop="24dp"
                android:text="PERSONAL INFO"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvChangePhoto" />

            <LinearLayout
                android:id="@+id/nameRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/lblPersonalInfo">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView style="@style/HikoraFieldLabel" android:text="First Name" />
                    <EditText android:id="@+id/etFirstName" style="@style/HikoraEditText" android:hint="Sienna" />
                </LinearLayout>

                <View android:layout_width="16dp" android:layout_height="0dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView style="@style/HikoraFieldLabel" android:text="Last Name" />
                    <EditText android:id="@+id/etLastName" style="@style/HikoraEditText" android:hint="Spiro" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/lblBio"
                style="@style/HikoraSectionLabel"
                android:layout_marginTop="20dp"
                android:text="BIO"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nameRow" />

            <EditText
                android:id="@+id/etBio"
                style="@style/HikoraEditText"
                android:layout_marginTop="8dp"
                android:gravity="top"
                android:minHeight="80dp"
                android:text="Trail lover. Mountain chaser."
                app:layout_constraintTop_toBottomOf="@id/lblBio" />

            <TextView
                android:id="@+id/lblPreferences"
                style="@style/HikoraSectionLabel"
                android:layout_marginTop="20dp"
                android:text="PREFERENCES"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etBio" />

            <include
                android:id="@+id/prefLocation"
                layout="@layout/item_preference_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/lblPreferences" />

            <include
                android:id="@+id/prefNotification"
                layout="@layout/item_preference_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/prefLocation" />

            <TextView
                android:id="@+id/lblHikingLevel"
                style="@style/HikoraSectionLabel"
                android:layout_marginTop="24dp"
                android:text="HIKING LEVEL"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/prefNotification" />

            <LinearLayout
                android:id="@+id/levelToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/lblHikingLevel">

                <TextView style="@style/HikoraLevelButton" android:text="Beginner" />
                <TextView style="@style/HikoraLevelButtonActive" android:layout_marginStart="8dp" android:text="Intermediate" />
                <TextView style="@style/HikoraLevelButton" android:layout_marginStart="8dp" android:text="Expert" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveChanges"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#8CA99C"
                android:text="Save Changes"
                android:textAllCaps="false"
                android:textColor="#0B301F"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/levelToggle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/avatarContainer"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:elevation="8dp"
            app:layout_constraintBottom_toTopOf="@id/whiteCard"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/whiteCard">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle_sage" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="TY"
                android:textColor="#0B301F"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_circle_white"
                android:elevation="2dp"
                android:padding="6dp"
                android:src="@drawable/ic_camera" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>